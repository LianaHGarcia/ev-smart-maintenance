us\" value={status} onChange={(e) => setStatus(e.target.value)}>\n            <option value=\"scheduled\">Scheduled</option>\n            <option value=\"in_progress\">In Progress</option>\n            <option value=\"completed\">Completed</option>\n          </select>\n        </div>\n        <button type=\"button\" onClick={handleUpdate}>Update Status</button>\n      </div>\n    </section>\n  );\n};\n\nexport default Maintenance;\n","import React from 'react';\n\nconst Reports: React.FC = () => {\n  return (\n    <section className=\"reports\">\n      <h1>Reports Analytics</h1>\n      <section>\n        <h2>Report Overview</h2>\n        <p>Here you can find various reports related to the EV smart maintenance.</p>\n      </section>\n      <section>\n        <h2>Data Insights</h2>\n        <p>Additional insights and analytics will be displayed here.</p>\n      </section>\n    </section>\n  );\n};\n\nexport default Reports;\n","import React from 'react';\n\nconst About: React.FC = () => {\n  return (\n    <section className=\"about\">\n      <h1>About EV Smart Maintenance System</h1>\n      <p>The Smart Maintenance System is designed to help users manage and maintain their electric vehicles effectively. With advanced diagnostic tools and user-friendly interfaces, it ensures the longevity and performance of your EV. Our system provides real-time analysis, maintenance reminders, and support resources.</p>\n      <h2>Features</h2>\n      <ul>\n        <li>Real-time diagnostics</li>\n        <li>Maintenance scheduling</li>\n        <li>Support documentation</li>\n        <li>User-friendly interface</li>\n      </ul>\n    </section>\n  );\n};\n\nexport default About;\n","import React from 'react';\nimport { Link, Outlet, useLocation } from 'react-router-dom';\n\nconst navItems = [\n    { name: 'Home', path: '/' },\n    { name: 'Dashboard', path: '/dashboard' },\n    { name: 'Maintenance', path: '/maintenance' },\n    { name: 'Reports', path: '/reports' },\n    { name: 'About', path: '/about' },\n];\n\nconst Layout: React.FC = () => {\n    const location = useLocation();\n\n    return (\n        <div className=\"App layout\">\n            <header className=\"header layout-header\">\n                <div className=\"header-content\">\n                    <img src=\"/logo.png\" alt=\"EV Smart Maintenance Logo\" className=\"header-logo\" />\n                </div>\n            </header>\n            <nav aria-label=\"Primary\">\n                <ul className=\"nav-list\">\n                    {navItems.map((item) => {\n                        const isActive = location.pathname === item.path;\n\n                        return (\n                            <li key={item.path} className=\"nav-item\">\n                                <Link to={item.path} className={isActive ? 'active' : ''}>\n                                    {item.name}\n                                </Link>\n                            </li>\n                        );\n                    })}\n                </ul>\n            </nav>\n            <main className=\"layout-content\">\n                <Outlet />\n            </main>\n            <footer className=\"layout-footer\">\n                <p>&copy; 2026 FutureNow Energy. All rights reserved.</p>\n            </footer>\n        </div>\n    );\n};\n\nexport default Layout;","import React from 'react';\nimport { Route, Routes } from 'react-router-dom';\nimport './App.css';\nimport Home from './pages/Home';\nimport Dashboard from './pages/Dashboard';\nimport Maintenance from './pages/Maintenance';\nimport Reports from './pages/Reports';\nimport About from './pages/About';\nimport Layout from './components/Layout/Layout';\n\nfunction App() {\n  return (\n    <Routes>\n      <Route element={<Layout />}>\n        <Route path=\"/\" element={<Home />} />\n        <Route path=\"/dashboard\" element={<Dashboard />} />\n        <Route path=\"/maintenance\" element={<Maintenance />} />\n        <Route path=\"/reports\" element={<Reports />} />\n        <Route path=\"/about\" element={<About />} />\n      </Route>\n    </Routes>\n  );\n}\n\nexport default App;\n","import React from 'react';\nimport ReactDOM from 'react-dom/client';\nimport { BrowserRouter } from 'react-router-dom';\nimport App from './App';\n\nconst container = document.getElementById('root');\nif (!container) {\n  throw new Error('Root container not found');\n}\n\nconst root = ReactDOM.createRoot(container);\n\nroot.render(\n  <React.StrictMode>\n    <BrowserRouter>\n      <App />\n    </BrowserRouter>\n  </React.StrictMode>\n);"]}}